int buscaRA (Aluno t[], int n, int RA){
  for (int i=0; i<n; i++){
    if (RA==t[i].RA){
      return 1; 
    }
  }
  return 0;
}

void insereAluno (Aluno t[], int n, int RA){
  printf ("Nome: ");
  fgets (t[n].nome, sizeof t[n].nome, stdin);
  t[n].nome [strlen (t[n].nome) -1) = '\0';
  t[n].RA = RA;
  printf ("RA: %d", t[n].RA);
  for (int i=0; i<3; i++){
    printf ("Nota %d: ",i+1);
    scanf ("%f", &t[n].nota[i]);
  }
  printf ("Frequencia: ");
  scanf ("%d", &t[n].frequencia);
}

void removeAluno (Aluno t[], int n, int RA){
  for(int i = 0; i < n; i++){
    if(t[i].RA == RA){
      t[i].RA = -1;
      t[i].nome[0] = '\0';
      t[i].frequencia = 0;
      for(int j = 0; j < 3; j++){
        t[i].notas[j] = 0;
      }
      printf("Aluno removido.\n");
    }
  }
}

