#include <stdio.h>
#include <string.h>

typedef struct {
  char nome[40];
  int RA;
  float nota[3];
  int frequencia;
}Aluno;

void imprimeMenu();
int buscaRA (Aluno [], int, int);
void insereAluno (Aluno [], int, int);
void removeAluno (Aluno [], int, int);
void imprimeAluno (Aluno [], int, int);
void alteraDados (Aluno [], int, int);

int main(){
  Aluno turma[50];
  int op;
  int n=0;
  int RA;

  while(op!=5){
    imprimeMenu();
    scanf("%d",&op);
    switch(op){
      case 1:
        if(n==50){
          printf("\nTurma Lotada!");
        }
        else{
          printf("\nRA: ");
          scanf("%d",&RA);
          if(buscaRA(turma,n,RA)==0){
            insereAluno(turma, n,RA);
            n++;
          }
          else{
            printf("\nAluno já cadastrado.");
          }
        }
        break;
      case 2:
        printf ("\nRA: ");
        scanf ("%d", &RA);
        if (buscaRA (turma, n, RA) == 1){
          printf ("\nAluno não encontrado");
        }
        else {
          removeAluno (turma, n, RA);
          n--;
        }
        break;
      case 3:
        printf ("\nRA: ");
        scanf ("%d", &RA); 
        if (buscaRA (turma, n, RA) == 1){
          imprimeAluno (turma, n, RA);
        }
        else {
          printf ("\nAluno não encontrado");
        }
        break;
      case 4:
        printf ("\nRA: ");
        scanf ("%d", &RA); 
        if (buscaRA (turma, n, RA) == 1){
          alteraDados (turma, n, RA);
        }
        else {
          printf ("\nAluno não encontrado");
        }
        break;
      case 5:
        printf ("\nTCHAU!");
        break;
      default:
        printf("\nOpção incorreta.");
        break;
    }
  }
}

void imprimeMenu (){
  printf ("\nMenu:");
  printf("\n1- inserir aluno");
  printf ("\n2- remover aluno");
  printf ("\n3- vizualizar aluno");
  printf ("\n4- altera dados aluno");
  printf ("\n5- sair");
  printf ("\nOpção: ");
}

int buscaRA (Aluno t[], int n, int RA){
  for (int i=0; i<n; i++){
    if (RA==t[i].RA){
      return 1; 
    }
  }
  return 0;
}

void insereAluno (Aluno t[], int n, int RA){
  printf ("Nome: ");
  fgets (t[n].nome, sizeof t[n].nome, stdin);
  t[n].nome [strlen (t[n].nome) -1) = '\0';
  t[n].RA = RA;
  printf ("RA: %d", t[n].RA);
  for (int i=0; i<3; i++){
    printf ("Nota %d: ",i+1);
    scanf ("%f", &t[n].nota[i]);
  }
  printf ("Frequencia: ");
  scanf ("%d", &t[n].frequencia);
}

void removeAluno (Aluno t[], int n, int RA){
  for(int i = 0; i < n; i++){
    if(t[i].RA == RA){
      for (int j=i; j<n -1; j++){
        t[j] = t[j+1];
      }
      printf("Aluno removido.\n");
      return;
    }
  }
}

void imprimeAluno (Aluno t[], int n, int RA){
  for (int i=0; i<n; i++){
    if (RA==t[i].RA){
      printf ("\nRA: %d", t[i].RA);
      printf ("\nNome: %s", t[i].nome);
      for (int j =0; j<3; j++){
        printf ("\nNota %d: %.2f", j+1, t[i].nota[j]);
      }
      printf ("\nFrequencia: %d", t[i].frequencia);
    }
  }
}

void alteraDados (Aluno t[], int n, int RA){
for (int i=0; i<n; i++){
    if (RA==t[i].RA){
      printf ("\nRA: %d", t[i].RA);
      printf ("\nNome: ");
      fgets (t[i].nome, sizeof (t[i].nome), stdin);
      t[i].nome [strlen(t[i].nome) - 1] = '\0';
      for (int j =0; j<3; j++){
        printf ("\nNota %d: ", j+1);
        scanf ("%d", &t[i].nota[j]);
      }
      printf ("\nFrequencia: ");
      scanf ("%d", &t[i].frequencia);
    }
  }
}
